---
import ProjectCard from './ProjectCard.astro';

interface Project {
  title: string;
  slug: string;
  year: number;
  location: string;
  summary: string;
  coverImage: string;
  projectType: string;
}

interface Props {
  projects: Project[];
  columns?: 2 | 3;
}

const { projects, columns = 3 } = Astro.props;

const gridClass = columns === 2
  ? 'grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12'
  : 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12';
---

<div class={gridClass}>
  {projects.map((project) => (
    <ProjectCard {...project} />
  ))}
</div>
