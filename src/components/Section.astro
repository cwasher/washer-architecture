---
interface Props {
  class?: string;
  id?: string;
  bg?: 'white' | 'light' | 'dark' | 'teal';
}

const { class: className = '', id, bg = 'white' } = Astro.props;

const bgClasses = {
  white: 'bg-white',
  light: 'bg-gray-50',
  dark: 'bg-brand-teal-dark text-white',
  teal: 'bg-brand-teal text-white',
};
---

<section id={id} class:list={['py-16 lg:py-24', bgClasses[bg], className]}>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <slot />
  </div>
</section>
