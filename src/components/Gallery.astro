---
interface Props {
  images: string[];
  alt: string;
}

const { images, alt } = Astro.props;
---

{images.length > 0 && (
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {images.map((src, i) => (
      <div class:list={['overflow-hidden rounded-sm bg-stone-200', i === 0 ? 'md:col-span-2' : '']}>
        <img
          src={src}
          alt={`${alt} - Image ${i + 1}`}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    ))}
  </div>
)}
