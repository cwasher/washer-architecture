---
interface Props {
  title: string;
  slug: string;
  year: number;
  location: string;
  summary: string;
  coverImage: string;
  projectType: string;
}

const { title, slug, year, location, summary, coverImage, projectType } = Astro.props;
---

<a href={`/projects/${slug}`} class="group block">
  <div class="aspect-[4/3] overflow-hidden rounded-sm bg-stone-200 mb-4">
    <img
      src={coverImage}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="space-y-1.5">
    <p class="text-xs font-medium uppercase tracking-wider text-stone-400">
      {projectType} &middot; {year}
    </p>
    <h3 class="text-lg font-semibold text-stone-900 group-hover:text-stone-600 transition-colors">
      {title}
    </h3>
    <p class="text-sm text-stone-500">{location}</p>
    <p class="text-sm text-stone-500 leading-relaxed line-clamp-2">{summary}</p>
  </div>
</a>
