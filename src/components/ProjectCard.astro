---
interface Props {
  title: string;
  slug: string;
  year: number;
  location: string;
  summary: string;
  coverImage: string;
  projectType: string;
}

const { title, slug, year, location, summary, coverImage, projectType } = Astro.props;
---

<a href={`/projects/${slug}`} class="group block">
  <div class="aspect-[4/3] overflow-hidden rounded bg-gray-200 mb-4">
    <img
      src={coverImage}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="space-y-1.5">
    <p class="text-xs font-heading font-semibold uppercase tracking-wider text-brand-orange-text">
      {projectType} &middot; {year}
    </p>
    <h3 class="text-lg font-heading font-bold text-brand-teal-dark group-hover:text-brand-orange transition-colors">
      {title}
    </h3>
    <p class="text-sm font-body text-brand-slate">{location}</p>
    <p class="text-sm font-body text-gray-500 leading-relaxed line-clamp-2">{summary}</p>
  </div>
</a>
