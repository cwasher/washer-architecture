---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<span class:list={['inline-block text-xs font-heading font-semibold uppercase tracking-wider px-3 py-1 rounded-full bg-brand-teal/10 text-brand-teal border border-brand-teal/20', className]}>
  <slot />
</span>
