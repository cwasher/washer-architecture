---
const currentYear = new Date().getFullYear();
---

<footer class="bg-stone-900 text-stone-300">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
      <div>
        <h3 class="text-white text-lg font-semibold tracking-tight mb-4">Washer Architecture</h3>
        <p class="text-sm leading-relaxed text-stone-400 max-w-xs">
          Thoughtful design for modern living. Crafting spaces that inspire, endure, and belong.
        </p>
      </div>

      <div>
        <h4 class="text-white text-sm font-semibold uppercase tracking-wider mb-4">Explore</h4>
        <ul class="space-y-2.5">
          <li><a href="/projects" class="text-sm text-stone-400 hover:text-white transition-colors">Projects</a></li>
          <li><a href="/about" class="text-sm text-stone-400 hover:text-white transition-colors">About</a></li>
          <li><a href="/contact" class="text-sm text-stone-400 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white text-sm font-semibold uppercase tracking-wider mb-4">Get in Touch</h4>
        <ul class="space-y-2.5 text-sm text-stone-400">
          <li>
            <a href="mailto:hello@washerarchitecture.com" class="hover:text-white transition-colors">
              hello@washerarchitecture.com
            </a>
          </li>
          <li>
            <a href="tel:+14795550142" class="hover:text-white transition-colors">
              (479) 555-0142
            </a>
          </li>
          <li>Bentonville, Arkansas</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-stone-800 text-sm text-stone-500 text-center">
      &copy; {currentYear} Washer Architecture. All rights reserved.
    </div>
  </div>
</footer>
