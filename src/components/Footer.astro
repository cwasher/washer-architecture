---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-teal-dark text-gray-300">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
      <div>
        <a href="/" class="inline-block mb-4">
          <img src="/logos/Logo-Color-Negative.svg" alt="Washer Architecture" class="h-14 w-auto" />
        </a>
        <p class="text-sm leading-relaxed text-gray-400 max-w-xs font-body">
          Thoughtful design for modern living. Crafting spaces that inspire, endure, and belong.
        </p>
      </div>

      <div>
        <h4 class="text-white text-sm font-heading font-semibold uppercase tracking-wider mb-4">Explore</h4>
        <ul class="space-y-2.5">
          <li><a href="/projects" class="text-sm font-body text-gray-400 hover:text-brand-orange transition-colors">Projects</a></li>
          <li><a href="/about" class="text-sm font-body text-gray-400 hover:text-brand-orange transition-colors">About</a></li>
          <li><a href="/contact" class="text-sm font-body text-gray-400 hover:text-brand-orange transition-colors">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white text-sm font-heading font-semibold uppercase tracking-wider mb-4">Get in Touch</h4>
        <ul class="space-y-2.5 text-sm font-body text-gray-400">
          <li>
            <a href="mailto:hello@washerarchitecture.com" class="hover:text-brand-orange transition-colors">
              hello@washerarchitecture.com
            </a>
          </li>
          <li>
            <a href="tel:+14795550142" class="hover:text-brand-orange transition-colors">
              (479) 555-0142
            </a>
          </li>
          <li>Bentonville, Arkansas</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-brand-teal text-sm text-gray-500 text-center font-body">
      &copy; {currentYear} Washer Architecture. All rights reserved.
    </div>
  </div>
</footer>
