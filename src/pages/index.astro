---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import heroImage from '../assets/hero/home-hero.jpg';

const heroWidths = [640, 960, 1280, 1600, 1920, 2560];

const heroAvif = await Promise.all(
  heroWidths.map((width) =>
    getImage({ src: heroImage, width, format: 'avif', quality: 55 })
  )
);
const heroWebp = await Promise.all(
  heroWidths.map((width) =>
    getImage({ src: heroImage, width, format: 'webp', quality: 70 })
  )
);
const heroFallback = await getImage({
  src: heroImage,
  width: 1600,
  format: 'jpg',
  quality: 72,
});

const heroAvifSrcset = heroAvif
  .map((img, i) => `${img.src} ${heroWidths[i]}w`)
  .join(', ');
const heroWebpSrcset = heroWebp
  .map((img, i) => `${img.src} ${heroWidths[i]}w`)
  .join(', ');
const heroSizes = '100vw';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 6)
  .map((p) => ({
    title: p.data.title,
    slug: p.id,
    year: p.data.year,
    location: p.data.location,
    summary: p.data.summary,
    coverImage: p.data.coverImage,
    projectType: p.data.projectType,
  }));

const services = [
  { title: 'Custom Homes', desc: 'Ground-up residential design tailored to your site, lifestyle, priorities, and long-term goals.' },
  { title: 'Renovations & Additions', desc: 'Thoughtful improvements that respect the existing home while making it work better for the way you live now.' },
  { title: 'Residential Planning', desc: 'Programming, space planning, feasibility studies, and early design guidance to help define scope before major decisions are made.' },
  { title: 'Construction Documents', desc: 'Detailed drawings, specifications, and coordinated documents that communicate the design clearly to builders, consultants, and permitting authorities.' },
  { title: 'High-Performance Design', desc: 'Envelope, systems, orientation, comfort, and durability considered early in the process — not added as an afterthought.' },
  { title: 'Construction Support', desc: 'Site visits, observation reports, shop drawing review, and communication during construction to help protect the design intent.' },
];

const process = [
  { step: '01', title: 'Discover', desc: 'Every home starts with listening. We take time to understand your needs, routines, site, budget, and vision so the design is rooted in the way you actually live.' },
  { step: '02', title: 'Design', desc: 'We turn what we’ve learned into ideas. Through drawings, sketches, and 3D studies, we explore possibilities, test layouts, refine materials, and shape the home into a clear architectural direction.' },
  { step: '03', title: 'Document', desc: 'With the design in place, we prepare the drawings and details needed to price, permit, and build the project. The goal is a clear, coordinated set of documents that helps the construction team understand the intent.' },
  { step: '04', title: 'Support', desc: 'As the project moves into construction, we stay available as a resource for you and the builder. We help clarify drawings, review progress, and assist with decisions that come up along the way.' },
];
---

<BaseLayout
  title="Home"
  transparentHeader
  preloadImages={[
    {
      imagesrcset: heroAvifSrcset,
      imagesizes: heroSizes,
      type: 'image/avif',
    },
  ]}
>
  <section class="relative min-h-screen flex items-center bg-brand-teal-dark overflow-hidden">
    <picture>
      <source type="image/avif" srcset={heroAvifSrcset} sizes={heroSizes} />
      <source type="image/webp" srcset={heroWebpSrcset} sizes={heroSizes} />
      <img
        src={heroFallback.src}
        alt=""
        width={heroImage.width}
        height={heroImage.height}
        fetchpriority="high"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover"
      />
    </picture>
    <div class="absolute inset-0 bg-brand-teal-dark/70"></div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-32 lg:py-40 w-full">
      <div class="max-w-3xl">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-heading font-extrabold text-white leading-tight">
          Architecture for homes that<br /><span class="text-brand-orange">live well.</span>
        </h1>
        <p class="mt-6 text-lg md:text-xl font-body text-white/85 leading-relaxed max-w-2xl">
          Washer Architecture designs thoughtful, high-performance homes, renovations, and residential spaces shaped around the way you live, the character of your site, and the long-term value of building well.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <Button href="/contact" variant="primary" size="lg">Start a Project</Button>
          <Button href="/projects" variant="outline-light" size="lg">View Projects</Button>
        </div>
      </div>
    </div>
    <a
      href="#featured-projects"
      aria-label="Scroll to content"
      class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/80 hover:text-white transition-colors animate-bounce-slow"
    >
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </section>

  <Section bg="white" id="featured-projects">
    <div class="text-center mb-12 lg:mb-16">
      <p class="text-xs font-heading font-semibold uppercase tracking-widest text-brand-orange-text mb-3">Selected Work</p>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-teal-dark">Featured Projects</h2>
    </div>
    <ProjectGrid projects={featuredProjects} />
    <div class="text-center mt-12">
      <Button href="/projects" variant="secondary">View All Projects</Button>
    </div>
  </Section>

  <Section bg="light">
    <div class="text-center mb-12 lg:mb-16">
      <p class="text-xs font-heading font-semibold uppercase tracking-widest text-brand-orange-text mb-3">What We Do</p>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-teal-dark">Services & Capabilities</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map(({ title, desc }) => (
        <div class="bg-white p-6 rounded-lg border border-gray-200 hover:border-brand-orange/30 hover:shadow-md transition-all">
          <h3 class="text-base font-heading font-bold text-brand-teal-dark mb-2">{title}</h3>
          <p class="text-sm font-body text-gray-600 leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section bg="white">
    <div class="text-center mb-12 lg:mb-16">
      <p class="text-xs font-heading font-semibold uppercase tracking-widest text-brand-orange-text mb-3">How We Work</p>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-teal-dark">Our Process</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {process.map(({ step, title, desc }) => (
        <div>
          <p class="text-3xl font-heading font-extrabold text-brand-orange/20 mb-1">{step}</p>
          <h3 class="text-lg font-heading font-bold text-brand-teal-dark mb-2">{title}</h3>
          <p class="text-sm font-body text-gray-600 leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section bg="light">
    <div class="max-w-3xl mx-auto text-center">
      <svg class="w-8 h-8 mx-auto mb-6 text-brand-orange/40" fill="currentColor" viewBox="0 0 24 24">
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
      </svg>
      <blockquote class="text-xl md:text-2xl font-body italic text-brand-teal-dark leading-relaxed">
        "Working with Washer Architecture felt like a true partnership. They listened deeply, challenged our assumptions in the best way, and delivered a home that exceeds what we imagined."
      </blockquote>
      <div class="mt-6">
        <p class="text-sm font-heading font-bold text-brand-teal-dark">Sarah & James Mitchell</p>
        <p class="text-sm font-body text-brand-slate">Cedar Ridge Residence</p>
      </div>
    </div>
  </Section>

  <Section bg="dark">
    <div class="text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-4">Ready to start the conversation?</h2>
      <p class="text-white/70 text-lg mb-8 max-w-xl mx-auto font-body">
        Whether you are planning a new home, renovation, or early feasibility study, the first step is a conversation. Share a little about your project, your site, and what you hope to create.
      </p>
      <a href="/contact" class="inline-flex items-center justify-center font-heading font-semibold uppercase tracking-wider rounded text-sm px-8 py-3.5 bg-brand-orange text-white hover:bg-brand-orange-dark transition-colors focus:outline-none focus:ring-2 focus:ring-brand-orange/50 focus:ring-offset-2 focus:ring-offset-brand-teal">
        Start a Project
      </a>
    </div>
  </Section>
</BaseLayout>
