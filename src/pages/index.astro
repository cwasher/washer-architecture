---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 6)
  .map((p) => ({
    title: p.data.title,
    slug: p.id,
    year: p.data.year,
    location: p.data.location,
    summary: p.data.summary,
    coverImage: p.data.coverImage,
    projectType: p.data.projectType,
  }));

const services = [
  { title: 'Custom Homes', desc: 'Ground-up residential design tailored to your site, lifestyle, and vision.' },
  { title: 'Renovations', desc: 'Thoughtful transformations that honor existing character while modernizing for today.' },
  { title: 'Multi-Family', desc: 'Townhomes, duplexes, and small apartment buildings designed for livability and community.' },
  { title: 'Light Commercial', desc: 'Restaurants, retail, and creative workspaces with personality and purpose.' },
  { title: 'Interior Design', desc: 'Material selection, custom millwork, and spatial planning from concept to completion.' },
  { title: 'Feasibility Studies', desc: 'Site analysis, zoning review, and budget guidance before you commit.' },
];

const process = [
  { step: '01', title: 'Discover', desc: 'We listen. Site visits, conversations, and research to understand your goals, constraints, and aspirations.' },
  { step: '02', title: 'Design', desc: 'Iterative sketching and modeling to explore possibilities and refine the concept into a clear direction.' },
  { step: '03', title: 'Document', desc: 'Detailed construction drawings and specifications that bring the design to life with precision.' },
  { step: '04', title: 'Support', desc: 'Construction administration to ensure the built result matches the design intent.' },
];
---

<BaseLayout title="Home">
  <section class="relative bg-stone-50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-24 lg:py-36">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-stone-900 leading-tight tracking-tight">
          Architecture that<br />belongs here.
        </h1>
        <p class="mt-6 text-lg md:text-xl text-stone-500 leading-relaxed max-w-2xl">
          Washer Architecture designs homes, renovations, and community spaces rooted in the landscape and culture of Northwest Arkansas.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <Button href="/projects" variant="primary" size="lg">View Projects</Button>
          <Button href="/contact" variant="secondary" size="lg">Start a Project</Button>
        </div>
      </div>
    </div>
  </section>

  <Section bg="white">
    <div class="text-center mb-12 lg:mb-16">
      <p class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-3">Selected Work</p>
      <h2 class="text-3xl md:text-4xl font-bold text-stone-900">Featured Projects</h2>
    </div>
    <ProjectGrid projects={featuredProjects} />
    <div class="text-center mt-12">
      <Button href="/projects" variant="secondary">View All Projects</Button>
    </div>
  </Section>

  <Section bg="light">
    <div class="text-center mb-12 lg:mb-16">
      <p class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-3">What We Do</p>
      <h2 class="text-3xl md:text-4xl font-bold text-stone-900">Services & Capabilities</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map(({ title, desc }) => (
        <div class="bg-white p-6 rounded border border-stone-200">
          <h3 class="text-base font-semibold text-stone-900 mb-2">{title}</h3>
          <p class="text-sm text-stone-500 leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section bg="white">
    <div class="text-center mb-12 lg:mb-16">
      <p class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-3">How We Work</p>
      <h2 class="text-3xl md:text-4xl font-bold text-stone-900">Our Process</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {process.map(({ step, title, desc }) => (
        <div>
          <p class="text-sm font-semibold text-stone-300 mb-2">{step}</p>
          <h3 class="text-lg font-semibold text-stone-900 mb-2">{title}</h3>
          <p class="text-sm text-stone-500 leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section bg="light">
    <div class="max-w-3xl mx-auto text-center">
      <svg class="w-8 h-8 mx-auto mb-6 text-stone-300" fill="currentColor" viewBox="0 0 24 24">
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
      </svg>
      <blockquote class="text-xl md:text-2xl font-medium text-stone-800 leading-relaxed">
        "Working with Washer Architecture felt like a true partnership. They listened deeply, challenged our assumptions in the best way, and delivered a home that exceeds what we imagined."
      </blockquote>
      <div class="mt-6">
        <p class="text-sm font-semibold text-stone-900">Sarah & James Mitchell</p>
        <p class="text-sm text-stone-500">Cedar Ridge Residence</p>
      </div>
    </div>
  </Section>

  <Section bg="dark">
    <div class="text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Ready to start your project?</h2>
      <p class="text-stone-400 text-lg mb-8 max-w-xl mx-auto">
        Every great building begins with a conversation. Tell us about your vision and we'll take it from there.
      </p>
      <Button href="/contact" variant="primary" size="lg">
        Get in Touch
      </Button>
    </div>
  </Section>
</BaseLayout>
