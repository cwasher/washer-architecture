---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';

const values = [
  { title: 'Listening First', desc: 'Good design begins with understanding. We take time to learn how you live, what you value, what your site offers, and what constraints need to be addressed before design decisions are made.' },
  { title: 'Thoughtful Performance', desc: 'A successful home should be beautiful, comfortable, efficient, durable, and responsive to its site. Performance is considered early, alongside layout, light, materials, and daily livability.' },
  { title: 'Clarity Through Detail', desc: 'Clear drawings and careful coordination help protect the design intent. We believe good documentation creates better decisions, better communication, and a smoother path to construction.' },
];

const services = [
  'Schematic Design',
  'Design Development',
  'Construction Documents',
  'Construction Administration',
  'Interior Design & Material Selection',
  'Feasibility & Site Analysis',
  'Zoning & Code Consultation',
  'Sustainable Design Strategy',
];
---

<BaseLayout title="About" description="Learn about Washer Architecture — our story, values, and approach to design in Northwest Arkansas.">
  <Section bg="white">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16 items-start">
      <div class="lg:col-span-3 order-2 lg:order-1">
        <p class="text-xs font-heading font-semibold uppercase tracking-widest text-brand-orange-text mb-3">About</p>
        <h1 class="text-3xl md:text-4xl font-heading font-bold text-brand-teal-dark">Thoughtful homes. Clear process.</h1>
        <div class="mt-8 space-y-5 font-body text-gray-600 leading-relaxed">
          <p>
            Washer Architecture is a residential architecture practice focused on custom homes, renovations, and high-performance design. Led by architect Chris Washer, the practice helps homeowners turn early ideas into thoughtful, buildable, and deeply personal places to live.
          </p>
          <p>
            Designing a home is both an emotional and financial investment. It requires trust, clear communication, and a process that helps make decisions feel less overwhelming. Washer Architecture was built around that belief.
          </p>
          <p>
            Chris brings a detail-oriented and technically grounded approach to residential design, using careful planning, three-dimensional modeling, and coordinated construction documents to help clients, builders, and consultants stay aligned from concept through construction.
          </p>
          <p>
            The work is rooted in listening first: understanding how you live, what you value, what your site offers, and what constraints need to be addressed. From there, the design process moves from discovery to design, documentation, and construction support — always with the goal of creating a home that feels considered, comfortable, durable, and true to the people who live there.
          </p>
        </div>
      </div>

      <div class="lg:col-span-2 order-1 lg:order-2">
        <figure class="lg:sticky lg:top-28">
          <div class="relative aspect-[4/5] w-full max-w-xs mx-auto lg:max-w-none rounded-lg overflow-hidden bg-gradient-to-br from-brand-teal-dark to-brand-teal shadow-md ring-1 ring-brand-teal-dark/10">
            <div class="absolute inset-0 flex items-center justify-center">
              <svg class="w-24 h-24 text-white/30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 12c2.7 0 4.9-2.2 4.9-4.9S14.7 2.2 12 2.2 7.1 4.4 7.1 7.1 9.3 12 12 12zm0 2.4c-3.3 0-9.8 1.6-9.8 4.9v2.4h19.6v-2.4c0-3.3-6.5-4.9-9.8-4.9z"/>
              </svg>
            </div>
            <div class="absolute bottom-3 left-3 right-3">
              <span class="inline-block text-[10px] font-heading font-semibold uppercase tracking-widest text-white/80 bg-black/30 backdrop-blur-sm px-2 py-1 rounded">Portrait coming soon</span>
            </div>
          </div>
          <figcaption class="mt-3 text-center text-xs font-heading uppercase tracking-widest text-brand-slate">
            Principal &amp; Founder
          </figcaption>
        </figure>
      </div>
    </div>
  </Section>

  <Section bg="light">
    <div class="text-center mb-12 lg:mb-16">
      <p class="text-xs font-heading font-semibold uppercase tracking-widest text-brand-orange-text mb-3">What Guides Us</p>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-teal-dark">Our Values</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {values.map(({ title, desc }) => (
        <div class="bg-white p-6 rounded-lg border border-gray-200 hover:border-brand-orange/30 hover:shadow-md transition-all">
          <h3 class="text-base font-heading font-bold text-brand-teal-dark mb-2">{title}</h3>
          <p class="text-sm font-body text-gray-600 leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section bg="dark">
    <div class="text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-4">Let’s talk about home.</h2>
      <p class="text-white/70 text-lg mb-8 max-w-xl mx-auto font-body">
        Every project starts with a few good questions. Tell me what you’re planning, where you are in the process, and what kind of home you hope to create.
      </p>
      <a href="/contact" class="inline-flex items-center justify-center font-heading font-semibold uppercase tracking-wider rounded text-sm px-8 py-3.5 bg-brand-orange text-white hover:bg-brand-orange-dark transition-colors focus:outline-none focus:ring-2 focus:ring-brand-orange/50 focus:ring-offset-2 focus:ring-offset-brand-teal">
        Start a Conversation
      </a>
    </div>
  </Section>
</BaseLayout>
