---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

const values = [
  {
    title: 'Listening First',
    desc: 'Good design begins with understanding. We take time to learn how you live, what you value, what your site offers, and what constraints need to be addressed before design decisions are made.',
  },
  {
    title: 'Thoughtful Performance',
    desc: 'A successful home should be beautiful, comfortable, efficient, durable, and responsive to its site. Performance is considered early, alongside layout, light, materials, and daily livability.',
  },
  {
    title: 'Clarity Through Detail',
    desc: 'Clear drawings and careful coordination help protect the design intent. Good documentation creates better decisions, better communication, and a smoother path to construction.',
  },
];
---

<BaseLayout title="About" description="Learn about Washer Architecture — our story, values, and approach to residential design in Northwest Arkansas.">

  <!-- Hero / Intro -->
  <Section bg="white">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16 items-start">

      <!-- Text -->
      <div class="lg:col-span-3 order-2 lg:order-1">
        <p class="text-xs font-heading font-semibold uppercase tracking-widest text-brand-orange-text mb-3">About</p>
        <h1 class="text-3xl md:text-4xl font-heading font-bold text-brand-teal-dark leading-tight">Thoughtful homes. Clear process.</h1>
        <div class="mt-6 space-y-4 font-body text-gray-600 leading-relaxed">
          <p>
            Washer Architecture is a residential architecture practice focused on custom homes, renovations, and high-performance design. Led by architect Chris Washer, the practice helps homeowners turn early ideas into thoughtful, buildable, and deeply personal places to live.
          </p>
          <p>
            Designing a home is both an emotional and financial investment. It requires trust, clear communication, and a process that helps make decisions feel less overwhelming.
          </p>
        </div>
      </div>

      <!-- Portrait -->
      <div class="lg:col-span-2 order-1 lg:order-2">
        <figure>
          <div class="relative aspect-[4/5] w-full max-w-xs mx-auto lg:max-w-none rounded-lg overflow-hidden bg-gradient-to-br from-brand-teal-dark to-brand-teal shadow-md ring-1 ring-brand-teal-dark/10">
            <div class="absolute inset-0 flex items-center justify-center">
              <svg class="w-24 h-24 text-white/30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 12c2.7 0 4.9-2.2 4.9-4.9S14.7 2.2 12 2.2 7.1 4.4 7.1 7.1 9.3 12 12 12zm0 2.4c-3.3 0-9.8 1.6-9.8 4.9v2.4h19.6v-2.4c0-3.3-6.5-4.9-9.8-4.9z"/>
              </svg>
            </div>
          </div>
          <figcaption class="mt-3 text-center">
            <p class="text-sm font-heading font-semibold text-brand-teal-dark">Chris Washer</p>
            <p class="text-xs font-heading uppercase tracking-widest text-brand-slate mt-0.5">Owner, Architect</p>
          </figcaption>
        </figure>
      </div>

    </div>
  </Section>

  <!-- About Chris -->
  <Section bg="light">
    <div class="max-w-3xl">
      <p class="text-xs font-heading font-semibold uppercase tracking-widest text-brand-orange-text mb-3">About Chris</p>
      <div class="space-y-4 font-body text-gray-600 leading-relaxed">
        <p>
          Chris Washer is the owner and architect behind Washer Architecture. His work focuses on residential design, high-performance homes, and clear technical documentation that supports better construction outcomes.
        </p>
        <p>
          Chris approaches architecture as both a creative and practical discipline. He enjoys the early conversations that uncover how a client wants to live, but also values the detailed work required to turn those ideas into coordinated drawings, buildable details, and clear decisions.
        </p>
        <p>
          Through Washer Architecture, Chris works directly with clients to guide projects from early vision and site planning through design development, construction documents, and construction support.
        </p>
      </div>
    </div>
  </Section>

  <!-- Values -->
  <Section bg="white">
    <div class="mb-10 lg:mb-12">
      <p class="text-xs font-heading font-semibold uppercase tracking-widest text-brand-orange-text mb-3">What Guides the Work</p>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-teal-dark">Design values with practical follow-through.</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {values.map(({ title, desc }) => (
        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h3 class="text-base font-heading font-bold text-brand-teal-dark mb-2">{title}</h3>
          <p class="text-sm font-body text-gray-600 leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- CTA -->
  <Section bg="dark">
    <div class="text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-4">Ready to start the conversation?</h2>
      <p class="text-white/70 text-lg mb-8 max-w-xl mx-auto font-body">
        Whether you are planning a new home, renovation, or early feasibility study, the first step is a conversation. Share a little about your project, your site, and what you hope to create.
      </p>
      <a href="/contact" class="inline-flex items-center justify-center font-heading font-semibold uppercase tracking-wider rounded text-sm px-8 py-3.5 bg-brand-orange text-white hover:bg-brand-orange-dark transition-colors focus:outline-none focus:ring-2 focus:ring-brand-orange/50 focus:ring-offset-2 focus:ring-offset-brand-teal">
        Start a Conversation
      </a>
    </div>
  </Section>

</BaseLayout>
