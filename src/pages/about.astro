---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';

const values = [
  { title: 'Rooted Design', desc: 'We design for place — responding to climate, culture, and context rather than imposing a predetermined style.' },
  { title: 'Enduring Quality', desc: 'We choose materials and methods that age gracefully, favoring longevity over trends.' },
  { title: 'Honest Collaboration', desc: 'Great architecture emerges from open dialogue. We listen as much as we draw.' },
  { title: 'Responsible Practice', desc: 'We pursue energy efficiency, material stewardship, and designs that tread lightly on the land.' },
  { title: 'Craft & Detail', desc: 'We believe the difference between good and exceptional lives in the details — joinery, proportion, light.' },
];

const services = [
  'Schematic Design',
  'Design Development',
  'Construction Documents',
  'Construction Administration',
  'Interior Design & Material Selection',
  'Feasibility & Site Analysis',
  'Zoning & Code Consultation',
  'Sustainable Design Strategy',
];
---

<BaseLayout title="About" description="Learn about Washer Architecture — our story, values, and approach to design in Northwest Arkansas.">
  <Section bg="white">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16 items-start">
      <div class="lg:col-span-3 order-2 lg:order-1">
        <p class="text-xs font-heading font-semibold uppercase tracking-widest text-brand-orange-text mb-3">About</p>
        <h1 class="text-3xl md:text-4xl font-heading font-bold text-brand-teal-dark">A studio built on conviction.</h1>
        <div class="mt-8 space-y-5 font-body text-gray-600 leading-relaxed">
          <p>
            Washer Architecture is a design studio based in Bentonville, Arkansas, founded on the belief that good architecture belongs to its place. We work across scales — from single-family homes to mixed-use developments — with a consistent focus on craft, sustainability, and the human experience of space.
          </p>
          <p>
            Our practice began in 2015 with a simple premise: Northwest Arkansas deserves architecture that reflects its unique landscape, community, and ambition. Every project starts with deep listening — to the site, the client, and the culture — and evolves through rigorous design exploration into buildings that feel both inevitable and surprising.
          </p>
          <p>
            We are a small team by choice. This allows us to give every project the principal-level attention it deserves, from first sketch to final walkthrough. Our clients become collaborators, and their buildings become part of the ongoing story of this region.
          </p>
        </div>
      </div>

      <div class="lg:col-span-2 order-1 lg:order-2">
        <figure class="lg:sticky lg:top-28">
          <div class="relative aspect-[4/5] w-full max-w-xs mx-auto lg:max-w-none rounded-lg overflow-hidden bg-gradient-to-br from-brand-teal-dark to-brand-teal shadow-md ring-1 ring-brand-teal-dark/10">
            <div class="absolute inset-0 flex items-center justify-center">
              <svg class="w-24 h-24 text-white/30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 12c2.7 0 4.9-2.2 4.9-4.9S14.7 2.2 12 2.2 7.1 4.4 7.1 7.1 9.3 12 12 12zm0 2.4c-3.3 0-9.8 1.6-9.8 4.9v2.4h19.6v-2.4c0-3.3-6.5-4.9-9.8-4.9z"/>
              </svg>
            </div>
            <div class="absolute bottom-3 left-3 right-3">
              <span class="inline-block text-[10px] font-heading font-semibold uppercase tracking-widest text-white/80 bg-black/30 backdrop-blur-sm px-2 py-1 rounded">Portrait coming soon</span>
            </div>
          </div>
          <figcaption class="mt-3 text-center text-xs font-heading uppercase tracking-widest text-brand-slate">
            Principal &amp; Founder
          </figcaption>
        </figure>
      </div>
    </div>
  </Section>

  <Section bg="light">
    <div class="text-center mb-12 lg:mb-16">
      <p class="text-xs font-heading font-semibold uppercase tracking-widest text-brand-orange-text mb-3">What Guides Us</p>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-teal-dark">Our Values</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {values.map(({ title, desc }) => (
        <div class="bg-white p-6 rounded-lg border border-gray-200 hover:border-brand-orange/30 hover:shadow-md transition-all">
          <h3 class="text-base font-heading font-bold text-brand-teal-dark mb-2">{title}</h3>
          <p class="text-sm font-body text-gray-600 leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section bg="white">
    <div class="max-w-3xl">
      <p class="text-xs font-heading font-semibold uppercase tracking-widest text-brand-orange-text mb-3">What We Offer</p>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-teal-dark mb-8">Services</h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-3">
        {services.map((service) => (
          <li class="flex items-center font-body text-gray-700">
            <svg class="w-4 h-4 text-brand-orange-text mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            {service}
          </li>
        ))}
      </ul>
    </div>
  </Section>

  <Section bg="dark">
    <div class="text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-4">Let's build something meaningful.</h2>
      <p class="text-white/70 text-lg mb-8 max-w-xl mx-auto font-body">
        Whether you're dreaming of a new home, reimagining an existing space, or planning a commercial project, we'd love to hear about it.
      </p>
      <a href="/contact" class="inline-flex items-center justify-center font-heading font-semibold uppercase tracking-wider rounded text-sm px-8 py-3.5 bg-brand-orange text-white hover:bg-brand-orange-dark transition-colors focus:outline-none focus:ring-2 focus:ring-brand-orange/50 focus:ring-offset-2 focus:ring-offset-brand-teal">
        Start a Conversation
      </a>
    </div>
  </Section>
</BaseLayout>
